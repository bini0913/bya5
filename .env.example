# Vercel Project Settings -> Environment Variables
# Required for the public website, login, and Supabase-backed pages.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Optional aliases used by server code and local tooling. These may match the VITE_* values above.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Required only if server-only admin utilities are enabled/imported in a future change.
# Never expose this value to the browser and never prefix it with VITE_.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
